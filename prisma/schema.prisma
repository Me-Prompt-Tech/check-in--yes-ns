datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Employee {
  id                  String   @id @map("_id")
  firstName           String
  lastName            String
  department          String
  role                String
  username            String   @unique
  password            String
  roleType            String   @default("employee")
  status              String   @default("active")
  createdDate         String
  forcePasswordChange Boolean  @default(false)

  @@map("employees")
}

model Attendance {
  id           String @id @map("_id")
  employeeId   String
  date         String
  morningIn    String @default("-")
  lunchBreak   String @default("-")
  afternoonIn  String @default("-")
  leaveWork    String @default("-")
  status       String @default("Absent")
  earlyLeaveReason String?

  @@map("attendance")
}

model Department {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  name  String @unique
  
  @@map("departments")
}

model LeaveRequest {
  id                   String  @id @default(auto()) @map("_id") @db.ObjectId
  employeeId           String
  employeeName         String
  leaveType            String  // "sick", "personal", "vacation"
  startDate            String
  endDate              String
  reason               String
  status               String  @default("pending") // "pending", "approved", "rejected"
  adminNote            String?
  medicalCertFileData  String? // Base64 encoded file
  medicalCertFileName  String?
  createdAt            String

  @@map("leave_requests")
}

model EmployeePrefix {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  prefix String @unique
  label  String

  @@map("employee_prefixes")
}
