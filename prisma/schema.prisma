datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Employee {
  id                  String   @id @map("_id")
  firstName           String
  lastName            String
  department          String
  role                String
  username            String   @unique
  password            String
  roleType            String   @default("employee")
  status              String   @default("active")
  createdDate         String
  forcePasswordChange Boolean  @default(false)

  @@map("employees")
}

model Attendance {
  id           String @id @map("_id")
  employeeId   String
  date         String
  morningIn    String @default("-")
  lunchBreak   String @default("-")
  afternoonIn  String @default("-")
  leaveWork    String @default("-")
  status       String @default("Absent")

  @@map("attendance")
}
